function subscribeNewsletter(){
  const inp=document.getElementById('newsletterEmail');
  const val=inp.value.trim();
  // Strict email validation: must have chars@chars.chars
  const emailRx=/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;
  if(!val){
    flashInvalid(inp,'Please enter your email address');return;
  }
  if(!emailRx.test(val)){
    flashInvalid(inp,'Please enter a valid email (e.g. name@domain.com)');return;
  }
  inp.value='';
  inp.classList.remove('invalid');
  showToast('✓ Subscribed! Check your inbox for a welcome gift.');
}
function flashInvalid(el,msg){
  el.classList.remove('invalid');
  void el.offsetWidth; // reflow to restart animation
  el.classList.add('invalid');
  showToast(msg,'err');
  el.focus();
}

