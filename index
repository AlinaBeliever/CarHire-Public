function openCabinet(){
  if(!currentUser){openAuth('login');return}
  document.getElementById('cabinetAvatar').textContent=currentUser.name.slice(0,2).toUpperCase();
  document.getElementById('cabinetName').textContent=currentUser.name;
  document.getElementById('cabinetEmail').textContent=currentUser.email;
  document.querySelectorAll('.cabinet-tab').forEach((t,i)=>t.classList.toggle('active',i===0));
  renderCabinetTab('bookings');
  document.getElementById('cabinetModal').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeCabinet(){document.getElementById('cabinetModal').classList.remove('open');document.body.style.overflow=''}
function switchTab(btn,tab){
  document.querySelectorAll('.cabinet-tab').forEach(t=>t.classList.remove('active'));
  btn.classList.add('active');renderCabinetTab(tab);
}
function renderCabinetTab(tab){
  const el=document.getElementById('cabinetContent');
  if(tab==='bookings'){
    const bks=currentUser.bookings||[];
    if(!bks.length){
      el.innerHTML=`<div class="empty-state"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="color:var(--gray)"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg><p>No bookings yet. <a style="color:var(--red);cursor:pointer" onclick="closeCabinet();document.getElementById('vehicles').scrollIntoView({behavior:'smooth'})">Browse vehicles →</a></p></div>`;return;
    }
    el.innerHTML=bks.map(b=>`<div class="booking-card">
      <div class="booking-card-header">
        <div><div class="booking-card-name">${b.car}</div><div style="font-size:12px;color:var(--gray)">${b.id}</div></div>
        <div class="booking-status status-${b.status}">${b.status.toUpperCase()}</div>
      </div>
      <div class="booking-card-details">
        <div class="booking-detail-item"><strong>${b.from}</strong>Pick-up</div>
        <div class="booking-detail-item"><strong>${b.to}</strong>Return</div>
        <div class="booking-detail-item"><strong>${b.days} days</strong>Duration</div>
        <div class="booking-detail-item"><strong>${currSym}${cvt(b.totalEUR)}</strong>Total</div>
      </div></div>`).join('');
  }else if(tab==='profile'){
    const[fn,ln]=(currentUser.name+' ').split(' ');
    el.innerHTML=`<div class="profile-form">
      <div class="profile-row">
        <div class="profile-field"><label>First Name</label><input type="text" value="${fn||''}" id="pFN"></div>
        <div class="profile-field"><label>Last Name</label><input type="text" value="${ln||''}" id="pLN"></div>
      </div>
      <div class="profile-field"><label>Email</label><input type="email" value="${currentUser.email}" id="pEM"></div>
      <div class="profile-field"><label>Phone</label><input type="tel" value="${currentUser.phone||''}" placeholder="+30 XXX XXX XXXX" id="pPH"></div>
      <div class="profile-row">
        <div class="profile-field"><label>Date of Birth</label><input type="date" id="pDB"></div>
        <div class="profile-field"><label>Driver's License #</label><input type="text" placeholder="DL-XXXXXX" id="pDL"></div>
      </div>
      <button class="btn-red" style="padding:12px 32px;font-size:12px;letter-spacing:1px;text-transform:uppercase" onclick="saveProfile()">Save Changes</button>
      <button class="btn-outline" style="padding:12px 24px;font-size:12px;letter-spacing:1px;text-transform:uppercase;margin-left:10px;color:var(--gray)" onclick="logOut()">Log Out</button>
    </div>`;
  }else{
    el.innerHTML=`<div class="empty-state"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="color:var(--gray)"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg><p>Upload your driver's license and passport to speed up reservations.</p><button class="btn-red" style="margin-top:20px;padding:12px 32px;font-size:12px;letter-spacing:1px;text-transform:uppercase" onclick="showToast('Document upload — coming soon!')">Upload Documents</button></div>`;
  }
}
function saveProfile(){
  currentUser.name=(document.getElementById('pFN').value+' '+document.getElementById('pLN').value).trim();
  currentUser.email=document.getElementById('pEM').value;
  currentUser.phone=document.getElementById('pPH').value;
  document.getElementById('cabinetName').textContent=currentUser.name;
  document.getElementById('cabinetEmail').textContent=currentUser.email;
  document.getElementById('cabinetAvatar').textContent=currentUser.name.slice(0,2).toUpperCase();
  document.getElementById('navCabinetBtn').textContent=currentUser.name.split(' ')[0];
  showToast('✓ Profile updated!');
}
function logOut(){
  currentUser=null;closeCabinet();
  document.getElementById('navLoginBtn').style.display='';
  document.getElementById('navSignupBtn').style.display='';
  document.getElementById('navCabinetBtn').style.display='none';
  showToast('You have been logged out.');
}

