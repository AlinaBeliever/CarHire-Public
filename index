function openOffer(type){
  const d=offerData[type];
  document.getElementById('offerModalBg').style.backgroundImage=`url('${d.bg}')`;
  document.getElementById('offerModalTag').textContent=d.tag;
  document.getElementById('offerModalTitle').textContent=d.title;

  let body=`<p class="offer-modal-lead">${d.lead}</p>`;

  // Feature cards
  body+=`<div class="offer-modal-features">`;
  d.features.forEach(f=>{
    body+=`<div class="omf-card"><div class="omf-card-icon">${f.icon}</div><div class="omf-card-title">${f.title}</div><div class="omf-card-text">${f.text}</div></div>`;
  });
  body+=`</div>`;

  // Duration bands (only for duration type)
  if(type==='duration'&&d.discountBands){
    body+=`<h4 style="font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:1.5px;margin-bottom:16px;color:var(--light-gray)">Savings by Rental Period</h4>`;
    body+=`<div class="discount-bands">`;
    d.discountBands.forEach(b=>{
      body+=`<div class="discount-band">
        <div class="discount-band-fill" style="width:${b.fill}%"></div>
        <div class="discount-band-label">${b.label}</div>
        <div class="discount-band-pct">${b.pct}</div>
        <div class="discount-band-desc">${b.desc}</div>
      </div>`;
    });
    body+=`</div>`;
  }

  // Table (advance & discount types)
  if(d.table){
    body+=`<h4 style="font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:1.5px;margin-bottom:16px;color:var(--light-gray)">${d.tableTitle}</h4>`;
    body+=`<table class="offer-modal-table"><thead><tr>`;
    d.table.headers.forEach(h=>body+=`<th>${h}</th>`);
    body+=`</tr></thead><tbody>`;
    d.table.rows.forEach((row,i)=>{
      const badge=d.table.badges&&d.table.badges[i];
      body+=`<tr>`;
      row.forEach((cell,ci)=>{
        if(ci===0&&badge)body+=`<td>${cell} <span class="offer-table-badge">${badge}</span></td>`;
        else body+=`<td>${cell}</td>`;
      });
      body+=`</tr>`;
    });
    body+=`</tbody></table>`;
  }

  // Steps
  body+=`<h4 style="font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:1.5px;margin-bottom:16px;color:var(--light-gray)">How It Works</h4>`;
  body+=`<div class="offer-steps">`;
  d.steps.forEach((s,i)=>{
    body+=`<div class="offer-step"><div class="offer-step-num">0${i+1}</div><div class="offer-step-title">${['Choose','Set Dates','Apply','Enjoy'][i]||'Step '+(i+1)}</div><div class="offer-step-text">${s}</div></div>`;
  });
  body+=`</div>`;

  // CTA
  body+=`<div class="offer-modal-cta">
    <button class="btn-red" style="padding:14px 36px;font-size:13px;letter-spacing:2px;text-transform:uppercase" onclick="closeOffer();document.getElementById('vehicles').scrollIntoView({behavior:'smooth'})">Browse Vehicles →</button>
    <p class="offer-modal-note">No hidden fees. Free cancellation on most bookings.<br>Terms apply — see our full Booking Policy.</p>
  </div>`;

  document.getElementById('offerModalBody').innerHTML=body;
  document.getElementById('offerModal').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeOffer(){document.getElementById('offerModal').classList.remove('open');document.body.style.overflow=''}

