//  CUSTOM TIME PICKER
// ══════════════════════════════════════════════
function buildTimeOptions(){
  const opts=[];
  for(let h=0;h<24;h++){
    opts.push(`${String(h).padStart(2,'0')}:00`);
    opts.push(`${String(h).padStart(2,'0')}:30`);
  }
  return opts;
}
const timeOptions=buildTimeOptions();

function renderTimeDrop(dropId,valId,initial){
  const drop=document.getElementById(dropId);
  drop.innerHTML=timeOptions.map(t=>`
    <div class="time-option${t===initial?' active':''}" onclick="selectTime('${dropId}','${valId}','${t}')">
      <span class="time-dot"></span>${t}
    </div>`).join('');
}

function toggleTimePicker(which){
  const isPickup=which==='pickup';
  const dropId=isPickup?'tpPickupDrop':'tpReturnDrop';
  const dispId=isPickup?'tpPickupDisplay':'tpReturnDisplay';
  const otherDropId=isPickup?'tpReturnDrop':'tpPickupDrop';
  const otherDispId=isPickup?'tpReturnDisplay':'tpPickupDisplay';

  // close the other picker
  document.getElementById(otherDropId).classList.remove('open');
  document.getElementById(otherDispId).classList.remove('open');

  const drop=document.getElementById(dropId);
  const disp=document.getElementById(dispId);
  const isOpen=drop.classList.contains('open');
  drop.classList.toggle('open',!isOpen);
  disp.classList.toggle('open',!isOpen);

  // scroll active option into view
  if(!isOpen){
    setTimeout(()=>{
      const active=drop.querySelector('.active');
      if(active)active.scrollIntoView({block:'center'});
    },50);
  }
}

function selectTime(dropId,valId,time){
  document.getElementById(valId).textContent=time;
  document.getElementById(dropId).classList.remove('open');
  const disp=dropId==='tpPickupDrop'?'tpPickupDisplay':'tpReturnDisplay';
  document.getElementById(disp).classList.remove('open');
  // update active state
  document.querySelectorAll('#'+dropId+' .time-option').forEach(o=>{
    o.classList.toggle('active',o.textContent.trim()===time);
  });
}

// Close time dropdowns when clicking outside
document.addEventListener('click',e=>{
  if(!e.target.closest('.time-picker-wrap')){
    document.querySelectorAll('.time-dropdown').forEach(d=>d.classList.remove('open'));
    document.querySelectorAll('.time-display').forEach(d=>d.classList.remove('open'));
  }
  if(!e.target.closest('.lang-selector'))document.getElementById('currDropdown').classList.remove('open');
});

