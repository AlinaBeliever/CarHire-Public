<!-- STATS -->

<div class="stats-bar">
  <div class="stat"><div class="stat-num">850+</div><div class="stat-label">Happy Clients</div></div>
  <div class="stat-divider"></div>
  <div class="stat"><div class="stat-num">120+</div><div class="stat-label">Vehicles</div></div>
