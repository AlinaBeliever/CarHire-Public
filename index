let authMode='login';
function openAuth(mode){
  authMode=mode;
  const isL=mode==='login';
  document.getElementById('authTitle').textContent=isL?'Log In':'Create Account';
  document.getElementById('authSub').textContent=isL?'Welcome back to AutoHire':'Join thousands of happy drivers';
  document.getElementById('authSubmitBtn').textContent=isL?'Log In':'Sign Up';
  document.getElementById('authNameField').style.display=isL?'none':'';
  document.getElementById('authPassConfField').style.display=isL?'none':'';
  document.getElementById('authSwitch').innerHTML=isL
    ?`Don't have an account? <a onclick="openAuth('signup')">Sign Up</a>`
    :`Already have an account? <a onclick="openAuth('login')">Log In</a>`;
  document.getElementById('authModal').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeAuth(){document.getElementById('authModal').classList.remove('open');document.body.style.overflow=''}
function submitAuth(){
  const email=document.getElementById('authEmail').value.trim();
  const pass=document.getElementById('authPass').value;
  if(!email||!email.includes('@')){showToast('Enter a valid email','err');return}
  if(!pass||pass.length<6){showToast('Password must be at least 6 characters','err');return}
  if(authMode==='signup'){
    const name=document.getElementById('authName').value.trim();
    const conf=document.getElementById('authPassConf').value;
    if(!name){showToast('Enter your full name','err');return}
    if(pass!==conf){showToast('Passwords do not match','err');return}
    currentUser={name,email,phone:'',bookings:[]};
  }else{
    currentUser={name:email.split('@')[0].replace(/[._]/g,' '),email,phone:'',bookings:[...demoBookings]};
  }
  closeAuth();
  document.getElementById('navLoginBtn').style.display='none';
  document.getElementById('navSignupBtn').style.display='none';
  const btn=document.getElementById('navCabinetBtn');
  btn.style.display='';btn.textContent=currentUser.name.split(' ')[0];
  showToast('✓ Welcome, '+currentUser.name+'!');
}

