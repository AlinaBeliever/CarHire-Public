function initDates(){
  const today=new Date();
  const fmt=d=>d.toISOString().split('T')[0];
  const p=document.getElementById('heroPickup'),r=document.getElementById('heroReturn');
  p.min=fmt(today);p.value=fmt(today);
  const nxt=new Date(today);nxt.setDate(nxt.getDate()+3);
  r.min=fmt(today);r.value=fmt(nxt);
  p.addEventListener('change',()=>{
    const d=new Date(p.value);d.setDate(d.getDate()+1);
    r.min=p.value;
    if(new Date(r.value)<=new Date(p.value))r.value=d.toISOString().split('T')[0];
  });
  // build time dropdowns
  renderTimeDrop('tpPickupDrop','tpPickupVal','10:00');
  renderTimeDrop('tpReturnDrop','tpReturnVal','10:00');
}

